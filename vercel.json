{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/comments",
      "dest": "/api/comments/index.js",
      "methods": ["POST"]
    },

    {
      "src": "/(health|api|)",
      "dest": "/api/index.js"
    }
  ]
}
